# LINE Messaging API - Memo Bot
MEMO_BOT_CHANNEL_SECRET=your_memo_bot_channel_secret_here
MEMO_BOT_ACCESS_TOKEN=your_memo_bot_access_token_here

# PDF 解密密碼
PDF_PASSWORD=your_pdf_password_here
