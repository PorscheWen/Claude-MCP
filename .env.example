# Anthropic API Key
# 從 https://console.anthropic.com/ 獲取您的 API key
ANTHROPIC_API_KEY=your_api_key_here

# Notion API
NOTION_TOKEN=your_notion_token_here

# LINE Messaging API - What_To_Eat Bot
LINE_CHANNEL_SECRET=your_channel_secret_here
